# ============================================
# COLLEGE VOICE AGENT - Environment Variables
# ============================================
# Copy this file to local.env and fill in your values
# DO NOT commit local.env to version control!

# ============ REQUIRED API KEYS ============

# Groq API Key (Get free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Speechmatics API Key (Optional - for enhanced STT)
SPEECHMATICS_API_KEY=your_speechmatics_api_key_here


# ============ AUTHENTICATION ============

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JWT Secret Key (change this in production!)
SECRET_KEY=your-super-secret-key-change-in-production


# ============ COLLEGE INFORMATION ============

# Your college name
COLLEGE_NAME=Dr. B.C. Roy Engineering College

# Contact information (shown in chatbot)
ADMISSIONS_PHONE=+91-9876543210
SUPPORT_EMAIL=info@bcrengg.edu.in


# ============ DIRECTORIES ============

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./chroma_db

# Upload directory for documents
UPLOAD_DIR=./uploads

# Temporary audio files directory
TEMP_AUDIO_DIR=./temp_audio


# ============ OPTIONAL SETTINGS ============

# CORS Origins (comma-separated, or * for all)
CORS_ORIGINS=*

# Token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
